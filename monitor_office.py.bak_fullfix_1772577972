import os
import json
import time
from datetime import datetime
from typing import List, Dict, Tuple

import cv2
import requests
from dotenv import load_dotenv
import pymysql

from camera_people import PeopleCounter
from rtsp_snapshot import grab_frame_ffmpeg


def db_connect():
    host = (os.getenv("DB_HOST") or "127.0.0.1").strip()
    port = int(os.getenv("DB_PORT") or "3306")
    db = (os.getenv("DB_NAME") or "factory").strip()
    user = (os.getenv("DB_USER") or "").strip()
    password = (os.getenv("DB_PASSWORD") or "").strip()
    if not user:
        raise SystemExit("DB_USER is not set")
    return pymysql.connect(
        host=host,
        port=port,
        user=user,
        password=password,
        database=db,
        charset="utf8mb4",
        cursorclass=pymysql.cursors.DictCursor,
        autocommit=True,
    )


def load_cameras_from_env() -> List[Dict]:
    raw = (os.getenv("CAMERAS_JSON") or "").strip()
    if not raw:
        raise SystemExit("CAMERAS_JSON is not set")
    return json.loads(raw)


def select_camera(cameras: List[Dict], cam_id: str) -> Dict:
    for c in cameras:
        if c.get("id") == cam_id:
            return c
    raise SystemExit(f"Camera id not found in CAMERAS_JSON: {cam_id}")


def tg_send_message(token: str, chat_id: str, text: str) -> None:
    url = f"https://api.telegram.org/bot{token}/sendMessage"
    r = requests.post(url, data={"chat_id": chat_id, "text": text}, timeout=20)
    r.raise_for_status()


def tg_send_photo(token: str, chat_id: str, photo_path: str, caption: str) -> None:
    url = f"https://api.telegram.org/bot{token}/sendPhoto"
    with open(photo_path, "rb") as f:
        r = requests.post(
            url,
            data={"chat_id": chat_id, "caption": caption},
            files={"photo": f},
            timeout=30,
        )
    r.raise_for_status()


def query_office_active(conn) -> Tuple[int, List[str]]:
    office_work_name = (os.getenv("OFFICE_WORK_NAME") or "Работа в офисе").strip()
    active_status = (os.getenv("ACTIVE_WORK_STATUS") or "work").strip()

    sql = """
    SELECT
      u.fio
    FROM work w
    LEFT JOIN users u ON u.usid = w.usid
    LEFT JOIN tasks t ON t.task_id = w.task_id
    WHERE w.work_status = %s
      AND t.task_name = %s
    ORDER BY w.accept_dt DESC
    """

    with conn.cursor() as cur:
        cur.execute(sql, (active_status, office_work_name))
        rows = cur.fetchall()

    employees = []
    for r in rows:
        fio = (r.get("fio") or "").strip()
        if fio:
            employees.append(fio)

    return len(employees), employees


def save_snapshot_jpg(img_bgr, out_path: str) -> None:
    ok = cv2.imwrite(out_path, img_bgr)
    if not ok:
        raise RuntimeError("cv2.imwrite failed")


def fmt_duration(seconds: int) -> str:
    seconds = max(0, int(seconds))
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h > 0:
        return f"{h}ч {m}мин {s}сек"
    if m > 0:
        return f"{m}мин {s}сек"
    return f"{s}сек"


def main():
    load_dotenv()

    token = (os.getenv("TELEGRAM_BOT_TOKEN") or "").strip()
    chat_id = str(os.getenv("ADMIN_TELEGRAM_ID") or "").strip()
    if not token:
        raise SystemExit("TELEGRAM_BOT_TOKEN is not set")
    if not chat_id:
        raise SystemExit("ADMIN_TELEGRAM_ID is not set")

    cam_id = (os.getenv("OFFICE_CAMERA_ID") or "office").strip()
    cameras = load_cameras_from_env()
    cam = select_camera(cameras, cam_id)
    if not cam.get("enabled", True):
        raise SystemExit(f"Camera {cam_id} is disabled in CAMERAS_JSON")
    rtsp_url = (cam.get("rtsp_url") or "").strip()
    if not rtsp_url:
        raise SystemExit(f"Camera {cam_id} has no rtsp_url")

    interval = int(os.getenv("MONITOR_INTERVAL_SEC") or "10")
    window_count = int(os.getenv("MONITOR_WINDOW_COUNT") or "6")

    # минимальный интервал между ФОТО (чтобы не насыпало при дергании)
    photo_cooldown_sec = int(os.getenv("PHOTO_COOLDOWN_SEC") or "30")

    conf = float(os.getenv("DETECT_CONF") or "0.45")
    nms = float(os.getenv("DETECT_NMS") or "0.35")

    counter = PeopleCounter(
        prototxt_path="models/MobileNetSSD_deploy.prototxt",
        model_path="models/MobileNetSSD_deploy.caffemodel",
        conf_thresh=conf,
        nms_thresh=nms,
    )

    conn = db_connect()

    # --- state machine ---
    alarm_active = False
    alarm_started_ts = 0

    # подтверждения (debounce)
    bad_streak = 0       # подряд detected < expected
    good_streak = 0      # подряд detected >= expected (используем для "восстановлено")

    # "ухудшилось" — отслеживаем минимальный detected во время инцидента
    worst_detected = None   # type: int | None
    worst_gap = 0           # max(expected-detected)
    last_photo_ts = 0

    print(f"[monitor] cam={cam_id} interval={interval}s window={window_count} conf={conf} nms={nms}")

    while True:
        ts_str = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

        expected, employees = query_office_active(conn)

        # Если по БД никого не должно быть — сбрасываем состояние и не тревожим
        if expected <= 0:
            if alarm_active:
                now = int(time.time())
                dur = now - alarm_started_ts
                dur_txt = fmt_duration(dur)

                msg_lines = [
                    "✅ Ситуация восстановлена",
                    f"Камера: {cam.get('name', cam_id)} ({cam.get('room','')})",
                    f"Отсутствовали: {dur_txt}",
                    "Причина: активных задач больше нет",
                ]

                try:
                    tg_send_message(token, chat_id, "
".join(msg_lines))
                    print(f"[{ts_str}] RECOVERY sent (tasks gone, duration {dur_txt})")
                except Exception as e:
                    print(f"[{ts_str}] ERROR telegram: {e}")

                # reset incident
                alarm_active = False
                alarm_started_ts = 0
                worst_detected = None
                worst_gap = 0
                bad_streak = 0
                good_streak = 0

            print(f"[{ts_str}] expected=0 -> skip")
            time.sleep(interval)
            continue

        try:
            frame = grab_frame_ffmpeg(rtsp_url)
            detected = counter.count_people(frame)
        except Exception as e:
            print(f"[{ts_str}] ERROR camera: {e}")
            time.sleep(interval)
            continue

        gap = max(0, expected - detected)

        if detected < expected:
            bad_streak += 1
            good_streak = 0
            print(f"[{ts_str}] expected={expected} detected={detected} BAD ({bad_streak}/{window_count})")
        else:
            good_streak += 1
            bad_streak = 0
            print(f"[{ts_str}] expected={expected} detected={detected} OK ({good_streak}/{window_count})")

        now = int(time.time())

        # --- OK -> ALARM (после подтверждения окна) ---
        if (not alarm_active) and bad_streak >= window_count:
            alarm_active = True
            alarm_started_ts = now
            worst_detected = detected
            worst_gap = gap

            os.makedirs("photos", exist_ok=True)
            photo_path = f"photos/alarm_{cam_id}_{now}.jpg"
            save_snapshot_jpg(frame, photo_path)

            caption_lines = [
                "🚨 ТРЕВОГА: в офисе людей меньше, чем должно быть",
                f"Камера: {cam.get('name', cam_id)} ({cam.get('room','')})",
                f"expected={expected}, detected={detected}",
                "",
                f"Активно '{(os.getenv('OFFICE_WORK_NAME') or 'Работа в офисе')}' у сотрудников:",
            ]
            for name in employees:
                caption_lines.append(f"• {name}")

            try:
                tg_send_photo(token, chat_id, photo_path, "\n".join(caption_lines))
                last_photo_ts = now
                print(f"[{ts_str}] ALERT sent: {photo_path}")
            except Exception as e:
                print(f"[{ts_str}] ERROR telegram: {e}")

            # после отправки сбросим streak, чтобы не пере-триггерило сразу
            bad_streak = 0
            good_streak = 0

        # --- ALARM -> OK (восстановлено после подтверждения окна) ---
        if alarm_active and good_streak >= window_count:
            dur = now - alarm_started_ts
            dur_txt = fmt_duration(dur)

            msg_lines = [
                "✅ Ситуация восстановлена",
                f"Камера: {cam.get('name', cam_id)} ({cam.get('room','')})",
                f"Отсутствовали: {dur_txt}",
            ]

            # для истории можно добавить "насколько проседало"
            if worst_detected is not None:
                msg_lines.append(f"Минимум за инцидент: detected={worst_detected} (gap={worst_gap})")

            try:
                tg_send_message(token, chat_id, "\n".join(msg_lines))
                print(f"[{ts_str}] RECOVERY sent (duration {dur_txt})")
            except Exception as e:
                print(f"[{ts_str}] ERROR telegram: {e}")

            # reset incident
            alarm_active = False
            alarm_started_ts = 0
            worst_detected = None
            worst_gap = 0
            bad_streak = 0
            good_streak = 0

        # --- ALARM ongoing: if стало хуже -> фото + сообщение ---
        if alarm_active:
            # обновим worst на более плохое значение
            if worst_detected is None:
                worst_detected = detected
                worst_gap = gap

            became_worse = (gap > worst_gap) or (detected < (worst_detected if worst_detected is not None else detected))

            if became_worse:
                # чтобы не реагировать на одиночный глитч детекции — требуем 2 плохих подряд (на ухудшении)
                # проще: используем bad_streak (он уже растет когда detected<expected)
                # и отправляем фото только если мы сейчас в BAD и это ухудшение держится хотя бы 2 цикла
                if detected < expected and bad_streak >= 2 and (now - last_photo_ts) >= photo_cooldown_sec:
                    # фиксируем новый "худший" уровень
                    worst_detected = min(worst_detected, detected) if worst_detected is not None else detected
                    worst_gap = max(worst_gap, gap)

                    os.makedirs("photos", exist_ok=True)
                    photo_path = f"photos/worse_{cam_id}_{now}.jpg"
                    save_snapshot_jpg(frame, photo_path)

                    caption = (
                        "⚠️ УХУДШИЛОСЬ: людей стало ещё меньше\n"
                        f"Камера: {cam.get('name', cam_id)} ({cam.get('room','')})\n"
                        f"expected={expected}, detected={detected} (gap={gap})"
                    )
                    try:
                        tg_send_photo(token, chat_id, photo_path, caption)
                        last_photo_ts = now
                        print(f"[{ts_str}] WORSE sent: {photo_path}")
                    except Exception as e:
                        print(f"[{ts_str}] ERROR telegram: {e}")

        time.sleep(interval)


if __name__ == "__main__":
    main()
